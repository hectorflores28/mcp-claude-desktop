WHISPER_MODEL_SIZE=base
WHISPER_LANGUAGE=es
SAMPLE_RATE=16000
CHUNK=1024

# Umbral de volumen RMS para detectar voz (sube si hay mucho ruido ambiente)
SILENCE_THRESHOLD=500

# Segundos de silencio para cortar la grabación
SILENCE_DURATION=2.0

# Duración máxima de grabación en segundos
MAX_DURATION=30

# Índice del dispositivo de micrófono (dejar vacío para usar el default del sistema)
# Usa list_audio_devices para ver los índices disponibles
DEVICE_INDEX=
