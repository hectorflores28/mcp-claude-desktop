# Tamaño del modelo Whisper: tiny, base, small, medium, large-v3
# Más grande = más preciso pero más lento
WHISPER_MODEL_SIZE=base

# Idioma principal para transcripción (es=español, en=inglés)
WHISPER_LANGUAGE=es

# Frecuencia de muestreo del micrófono
SAMPLE_RATE=16000

# Umbral de silencio (0.01 recomendado, bajar si el mic es muy sensible)
SILENCE_THRESHOLD=0.01

# Segundos de silencio para cortar la grabación
SILENCE_DURATION=2.0

# Duración máxima de grabación en segundos
MAX_DURATION=30
